# ================================================================
# Ignite Automations — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ================================================================

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Upstash Redis ---
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# --- Base URL (your Railway or ngrok URL for webhooks) ---
BASE_URL=https://ignite-api.up.railway.app

# --- Stripe (for billing) ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Optional: default Vonage credentials (overridden per tenant) ---
VONAGE_API_KEY=
VONAGE_API_SECRET=

# --- Dashboard ---
DASHBOARD_URL=https://app.igniteautomations.io

# --- n8n (if self-hosted on Railway) ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
N8N_HOST=n8n.igniteautomations.io
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.igniteautomations.io/
